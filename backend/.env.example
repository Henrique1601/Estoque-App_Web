# Porta do servidor
PORT=3001

# String de conexão do Postgres (Railway fornece isso automaticamente)
DATABASE_URL=postgresql://usuario:senha@host:5432/nome_do_banco

# Segredo usado para assinar os tokens JWT (troque por um valor aleatório forte)
JWT_SECRET=troque_isso_por_uma_string_bem_aleatoria

# URL do frontend, usada para configurar o CORS
FRONTEND_URL=http://localhost:5173
